{% extends 'base.html.twig' %}

{% block title %}Mes Favoris — RecipeHub{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">⭐ Mes Favoris</h1>
        <a href="{{ path('app_recettes') }}" class="btn btn-outline-secondary">← Toutes les recettes</a>
    </div>

    {% if recettes is empty %}
        <div class="alert alert-info text-center py-5">
            <p class="fs-5 mb-2">Vous n'avez pas encore de recettes favorites.</p>
            <a href="{{ path('app_recettes') }}" class="btn btn-success mt-2">🍲 Découvrir des recettes</a>
        </div>
    {% else %}
        <div class="row g-4">
            {% for recette in recettes %}
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0">
                        {% if recette.imageName %}
                            <img src="{{ asset('uploads/recettes/' ~ recette.imageName) }}"
                                 class="card-img-top" style="height: 200px; object-fit: cover;"
                                 alt="{{ recette.titre }}">
                        {% else %}
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                                 style="height: 200px; font-size: 4rem;">
                                {{ recette.categorie ? recette.categorie.icone : '🍽️' }}
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">{{ recette.titre }}</h5>
                                {% if recette.difficulte == 'facile' %}
                                    <span class="badge bg-success">🟢 Facile</span>
                                {% elseif recette.difficulte == 'moyen' %}
                                    <span class="badge bg-warning text-dark">🟡 Moyen</span>
                                {% else %}
                                    <span class="badge bg-danger">🔴 Difficile</span>
                                {% endif %}
                            </div>
                            {% if recette.categorie %}
                                <small class="text-muted">{{ recette.categorie.icone }} {{ recette.categorie.nom }}</small>
                            {% endif %}
                            <p class="card-text text-muted mt-2" style="font-size: 0.9rem;">
                                {{ recette.description|slice(0, 100) }}{% if recette.description|length > 100 %}...{% endif %}
                            </p>
                            <div class="d-flex gap-3 text-muted small mb-2">
                                <span>⏱️ {{ recette.tempsPreparation }} min</span>
                                <span>👥 {{ recette.nbPersonnes }} pers.</span>
                            </div>
                            {% if recette.tags|length > 0 %}
                                <div class="mb-2">
                                    {% for tag in recette.tags %}
                                        <span class="badge rounded-pill" style="background-color: {{ tag.couleur }};">
                                            {{ tag.nom }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex gap-2">
                            <a href="{{ path('app_recette_detail', {id: recette.id}) }}"
                               class="btn btn-outline-success w-100">
                                Voir la recette →
                            </a>
                            <form method="post" action="{{ path('app_recette_favori_retirer', {id: recette.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('favori_retirer_' ~ recette.id) }}">
                                <button type="submit" class="btn btn-outline-warning">❌</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
