{% extends 'base.html.twig' %}

{% block title %}Recettes — RecipeHub{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">🍲 Toutes les recettes</h1>
        {% if is_granted('ROLE_CUISINIER') %}
            <a href="{{ path('app_recette_nouvelle') }}" class="btn btn-success">
                ➕ Nouvelle recette
            </a>
        {% endif %}
    </div>
    {# Search Form #}
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            {{ form_start(formulaireRecherche, {'attr': {'class': 'row g-3'}}) }}
                <div class="col-md-3">
                    {{ form_widget(formulaireRecherche.titre) }}
                </div>
                <div class="col-md-3">
                    {{ form_widget(formulaireRecherche.categorie) }}
                </div>
                <div class="col-md-3">
                    {{ form_widget(formulaireRecherche.difficulte) }}
                </div>
                <div class="col-md-2">
                    {{ form_widget(formulaireRecherche.tag) }}
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-success w-100">🔍</button>
                </div>
            {{ form_end(formulaireRecherche) }}
        </div>
    </div>

    {% if recettes is empty %}
        <div class="alert alert-info text-center py-5">
            <p class="fs-5 mb-0">Aucune recette pour le moment.</p>
            {% if is_granted('ROLE_CUISINIER') %}
                <a href="{{ path('app_recette_nouvelle') }}" class="btn btn-success mt-3">Créer la première recette</a>
            {% endif %}
        </div>
    {% else %}
        <div class="row g-4">
            {% for recette in recettes %}
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0">
                        {% if recette.imageName %}
                            <img src="{{ asset('uploads/recettes/' ~ recette.imageName) }}"
                                 class="card-img-top" style="height: 200px; object-fit: cover;"
                                 alt="{{ recette.titre }}">
                        {% else %}
                            <div class="card-img-top d-flex align-items-center justify-content-center bg-light"
                                 style="height: 200px; font-size: 4rem;">
                                {{ recette.categorie ? recette.categorie.icone : '🍽️' }}
                            </div>
                        {% endif %}
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">{{ recette.titre }}</h5>
                                {% if recette.difficulte == 'facile' %}
                                    <span class="badge bg-success">🟢 Facile</span>
                                {% elseif recette.difficulte == 'moyen' %}
                                    <span class="badge bg-warning text-dark">🟡 Moyen</span>
                                {% else %}
                                    <span class="badge bg-danger">🔴 Difficile</span>
                                {% endif %}
                            </div>
                            {% if recette.categorie %}
                                <small class="text-muted">{{ recette.categorie.icone }} {{ recette.categorie.nom }}</small>
                            {% endif %}
                            <p class="card-text text-muted mt-2" style="font-size: 0.9rem;">
                                {{ recette.description|slice(0, 100) }}{% if recette.description|length > 100 %}...{% endif %}
                            </p>
                            <div class="d-flex gap-3 text-muted small mb-2">
                                <span>⏱️ {{ recette.tempsPreparation }} min</span>
                                <span>👥 {{ recette.nbPersonnes }} pers.</span>
                            </div>
                            {# Tags #}
                            {% if recette.tags|length > 0 %}
                                <div class="mb-2">
                                    {% for tag in recette.tags %}
                                        <span class="badge rounded-pill" style="background-color: {{ tag.couleur }};">
                                            {{ tag.nom }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex gap-2">
                            <a href="{{ path('app_recette_detail', {id: recette.id}) }}"
                               class="btn btn-success w-100">
                                Voir la recette →
                            </a>
                            {% if app.user and (app.user == recette.auteur or is_granted('ROLE_ADMIN')) %}
                                <form method="post"
                                      action="{{ path('app_recette_supprimer', {id: recette.id}) }}"
                                      id="form-supprimer-{{ recette.id }}">
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('supprimer_' ~ recette.id) }}">
                                    <button type="button" class="btn btn-danger swal-delete"
                                            data-form-id="form-supprimer-{{ recette.id }}">
                                        🗑️
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% block javascripts %}
<script type="module">
import Swal from 'sweetalert2';

document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.swal-delete').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const formId = this.getAttribute('data-form-id');
            const form = document.getElementById(formId);
            Swal.fire({
                title: 'Supprimer cette recette ?',
                text: 'Cette action est irréversible !',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Oui, supprimer',
                cancelButtonText: 'Annuler'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
});
</script>
{% endblock %}
    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(recettes) }}
    </div>
{% endblock %}