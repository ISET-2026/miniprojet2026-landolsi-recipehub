{% extends 'base.html.twig' %}

{% block title %}Catégories — RecipeHub{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">📂 Catégories</h1>
        <a href="{{ path('app_categorie_nouvelle') }}" class="btn btn-success">➕ Nouvelle catégorie</a>
    </div>

    {% if categories is empty %}
        <div class="alert alert-info">Aucune catégorie pour le moment.</div>
    {% else %}
        <div class="row g-4">
            {% for categorie in categories %}
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <div class="fs-1 mb-2">{{ categorie.icone ?? '📂' }}</div>
                            <h5 class="fw-bold">{{ categorie.nom }}</h5>
                            {% if categorie.description %}
                                <p class="text-muted small">{{ categorie.description }}</p>
                            {% endif %}
                            <span class="badge bg-secondary">{{ categorie.recettes|length }} recette(s)</span>
                        </div>
                        <div class="card-footer bg-transparent border-0 text-center">
                            <form method="post"
                                  action="{{ path('app_categorie_supprimer', {id: categorie.id}) }}"
                                  onsubmit="return confirm('Supprimer cette catégorie ?');">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('supprimer_' ~ categorie.id) }}">
                                <button type="submit" class="btn btn-outline-danger btn-sm">🗑️ Supprimer</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}