<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}RecipeHub{% endblock %}</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&family=Fraunces:wght@500;600;700&display=swap" rel="stylesheet">

        <!-- Icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

        <!-- Template CSS -->
        <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/style.css') }}">

        {% block stylesheets %}{% endblock %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>
    <body style="display: flex; flex-direction: column; min-height: 100vh;">

        {# ===== TOP BAR ===== #}
        <div class="container-fluid py-2 border-bottom d-none d-lg-block" style="background: #f8f9fa;">
            <div class="container">
                <div class="d-flex justify-content-between">
                    <small><i class="fas fa-map-marker-alt me-2 text-success"></i>Tunis, Tunisie</small>
                    <small><i class="fas fa-envelope me-2 text-success"></i>contact@recipehub.com</small>
                </div>
            </div>
        </div>

        {# ===== NAVBAR ===== #}
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-success fs-3" href="{{ path('app_home') }}">
                    🍽️ RecipeHub
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" href="{{ path('app_home') }}">🏠 Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" href="{{ path('app_recettes') }}">🍲 Recettes</a>
                        </li>
                        {% if is_granted('ROLE_CUISINIER') %}
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" href="{{ path('app_recette_nouvelle') }}">➕ Nouvelle recette</a>
                            </li>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" href="{{ path('app_categories') }}">📂 Catégories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" href="{{ path('app_tags') }}">🏷️ Tags</a>
                            </li>
                        {% endif %}
                    </ul>
                    <div class="d-flex align-items-center gap-2">
                        {% if app.user %}
                            <span class="text-muted fw-semibold">👤 {{ app.user.userIdentifier }}</span>
                            <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">Déconnexion</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-success btn-sm">Connexion</a>
                            <a href="{{ path('app_register') }}" class="btn btn-success btn-sm">Inscription</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        {# ===== FLASH MESSAGES ===== #}
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'warning') }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# ===== MAIN CONTENT ===== #}
        <main class="container my-5" style="flex: 1;">
            {% block body %}{% endblock %}
        </main>

        {# ===== FOOTER ===== #}
        <footer class="bg-dark text-white pt-5 pb-3 mt-5">
            <div class="container">
                <div class="row g-4">
                    <div class="col-md-4">
                        <h5 class="text-success fw-bold">🍽️ RecipeHub</h5>
                        <p class="text-muted small">Découvrez et partagez vos recettes préférées avec notre communauté de cuisiniers passionnés.</p>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-bold">Navigation</h6>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_home') }}" class="text-muted text-decoration-none">Accueil</a></li>
                            <li><a href="{{ path('app_recettes') }}" class="text-muted text-decoration-none">Recettes</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h6 class="fw-bold">Contact</h6>
                        <p class="text-muted small">
                            <i class="fas fa-envelope me-2"></i>contact@recipehub.com<br>
                            <i class="fas fa-map-marker-alt me-2"></i>Tunis, Tunisie
                        </p>
                    </div>
                </div>
                <hr class="border-secondary">
                <p class="text-center text-muted small mb-0">
                    &copy; {{ "now"|date("Y") }} RecipeHub — Tous droits réservés.
                </p>
            </div>
        </footer>

        {# ===== JS ===== #}
        <script src="{{ asset('js/main.js') }}"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>